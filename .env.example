# TripGenie AI - Environment Configuration Template
PROJECT_NAME="TripGenie AI"
API_V1_STR="/api/v1"
FRONTEND_URL="http://localhost:5173"

# Security
# Generate using: openssl rand -hex 32
JWT_SECRET_KEY="replace-with-a-very-secure-random-hex-string-for-access-tokens"
JWT_REFRESH_SECRET_KEY="replace-with-a-very-secure-random-hex-string-for-refresh-tokens"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Connection (PostgreSQL)
# For docker-compose, use: postgresql://postgres:postgres@db:5432/tripgenie
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tripgenie"

# Redis Cache & Blocklist
# For docker-compose, use: redis://redis:6379/0
REDIS_URL="redis://localhost:6379/0"

# OAuth Credentials (Optional - scaffolded stubs)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
